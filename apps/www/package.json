{
  "name": "@nimbus/www",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Nimbus docs site + registry host. Deployed to https://nimbus-docs.com via Cloudflare Workers Static Assets.",
  "scripts": {
    "generate-registry": "tsx scripts/generate-registry.ts",
    "dev": "pnpm run generate-registry && astro dev",
    "build": "pnpm run generate-registry && astro build",
    "preview": "astro preview",
    "typecheck": "astro check",
    "preview:cf": "wrangler dev",
    "predeploy": "pnpm --filter nimbus-docs build && astro check && pnpm run build",
    "deploy": "wrangler deploy"
  },
  "dependencies": {
    "@astrojs/markdown-satteri": "0.2.1",
    "@astrojs/react": "^5.0.4",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@iconify-json/ph": "^1.2.0",
    "@resvg/resvg-js": "^2.6.2",
    "astro": "^6.4.0",
    "astro-icon": "^1.1.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.24",
    "nimbus-docs": "workspace:*",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "satori": "^0.26.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/mdx": "6.0.1",
    "@tailwindcss/postcss": "^4.1.4",
    "@types/node": "^20.17.0",
    "@types/react": "^19.2.6",
    "@types/react-dom": "^19.2.3",
    "pagefind": "^1.5.2",
    "tailwindcss": "^4.1.4",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "wrangler": "^4.95.0"
  }
}

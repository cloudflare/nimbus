---
/**
 * /components/[slug] — per-component showcase.
 *
 * Reads from the `components` content collection. Each entry's MDX body
 * supplies the Preview + Examples sections (via the `<Showcase>` and
 * `<Example>` wrappers); the route owns Installation + API reference
 * because they're driven by `manifests.ts` and the entry's frontmatter
 * `props` array, not by hand-authored prose.
 */
import { getCollection, getEntry, render } from "astro:content";
import ShowcaseLayout from "@/layouts/ShowcaseLayout.astro";
import PropTable from "@/components/showcase/PropTable.astro";
import { Breadcrumbs } from "@/components/ui/breadcrumbs";
import { PageActions } from "@/components/ui/page-actions";
import { PackageManagers } from "@/components/ui/package-managers";
import { Pagination } from "@/components/ui/pagination";
import { MANIFESTS } from "@/../registry/manifests";
import { getSidebar } from "nimbus-docs";
import type { TOCItem } from "nimbus-docs/types";

export const prerender = true;

export async function getStaticPaths() {
  const entries = await getCollection("components");
  return entries.map((e) => ({ params: { slug: e.id } }));
}

const { slug } = Astro.params;
if (!slug) return Astro.redirect("/404");

const manifest = MANIFESTS[slug as keyof typeof MANIFESTS];
if (!manifest || manifest.type !== "registry:ui") {
  return Astro.redirect("/404");
}

const entry = await getEntry("components", slug);
if (!entry) return Astro.redirect("/404");

const { tagline, props } = entry.data;
const hasProps = props.length > 0;

const sidebar = await getSidebar(`/components/${slug}`);

// Prev/next over the alphabetical list of registry:ui components in the
// collection. The components grid + sidebar already sort by manifest
// title; mirror that ordering here so the footer matches.
const allEntries = await getCollection("components");
const ordered = allEntries
  .map((e) => {
    const m = MANIFESTS[e.id as keyof typeof MANIFESTS];
    return { id: e.id, label: m?.type === "registry:ui" ? m.title : e.id };
  })
  .sort((a, b) => a.label.localeCompare(b.label));
const currentIndex = ordered.findIndex((e) => e.id === slug);
const prevEntry = currentIndex > 0 ? ordered[currentIndex - 1] : undefined;
const nextEntry = currentIndex < ordered.length - 1 ? ordered[currentIndex + 1] : undefined;
const prevNext = {
  prev: prevEntry ? { label: prevEntry.label, href: `/components/${prevEntry.id}` } : undefined,
  next: nextEntry ? { label: nextEntry.label, href: `/components/${nextEntry.id}` } : undefined,
};

const { Content, headings: bodyHeadings } = await render(entry);

const headings: TOCItem[] = [
  { depth: 2, text: "Installation", slug: "installation" },
  ...bodyHeadings
    .filter((h) => h.depth === 2 || h.depth === 3)
    .map((h) => ({ depth: h.depth as 2 | 3, text: h.text, slug: h.slug })),
  ...(hasProps
    ? [{ depth: 2 as const, text: "API reference", slug: "api-reference" }]
    : []),
];

const name = manifest.title;
const markdownUrl = Astro.site
  ? new URL(`/components/${slug}/index.md`, Astro.site).href
  : `/components/${slug}/index.md`;

const breadcrumbs = [
  { label: "Home", href: "/" },
  { label: "Components", href: "/components" },
  { label: name, href: `/components/${slug}` },
];
---

<ShowcaseLayout
  title={`${name} — Components`}
  description={tagline}
  markdownUrl={markdownUrl}
  sidebar={sidebar}
  headings={headings}
>
  <div
    class="nb-showcase-content mx-auto max-w-(--nb-content-max) px-4 lg:px-6 pt-8 pb-32"
  >
    <Breadcrumbs items={breadcrumbs} class="pb-2" />

    <h1
      class="text-foreground mb-0 leading-tight mt-6"
      style="font-size:var(--nb-h1-size);font-weight:var(--nb-h1-weight);letter-spacing:var(--nb-h1-tracking)"
    >
      {name}
    </h1>

    <p
      class="text-[0.9375rem] sm:text-[1.0625rem] text-muted-foreground leading-relaxed mt-2 mb-2"
    >
      {tagline}
    </p>

    <PageActions markdownUrl={markdownUrl} />

    <div class="mt-4 mb-16 h-px w-full bg-border" role="none"></div>

    <div class="flex flex-col gap-24">
      <section id="installation" class="scroll-mt-20 flex flex-col gap-5">
        <h2 class="text-xl font-semibold text-foreground tracking-tight">
          Installation
        </h2>
        <PackageManagers pkg="nimbus-docs" type="dlx" args={`add ${slug}`} />
      </section>

      <div class="nb-showcase-body flex flex-col gap-10">
        <Content />
      </div>

      {hasProps && (
        <section id="api-reference" class="scroll-mt-20 flex flex-col gap-6">
          <header>
            <h2 class="text-xl font-semibold text-foreground tracking-tight mb-1.5">
              API reference
            </h2>
            <p class="text-sm text-muted-foreground">
              Every prop the component accepts, sourced from a single declaration.
            </p>
          </header>
          <PropTable props={props} />
        </section>
      )}

      <Pagination prevNext={prevNext} class="mt-12" />
    </div>
  </div>
</ShowcaseLayout>

<style is:global>
  /* Showcase code blocks: hide the language badge — it's noise alongside
     the obvious component label. Also hide the language chip inside
     titled figcaptions; the filename stays. */
  .nb-showcase-content .nb-code-figure::before,
  .nb-showcase-content .nb-code-title-lang {
    display: none !important;
  }
  /* Preview + Code pair: drop the code's top border-radius and top border
     so the pair reads as a single box with the stage's bottom border as
     the divider. */
  .nb-showcase-pair-code .nb-code-figure {
    margin-top: 0;
    border-top: 0;
    border-top-left-radius: 0;
    border-top-right-radius: 0;
  }
  /* MDX body styling: section h2s match the surrounding chrome h2s; example
     h3s sit smaller above their preview stages with a tight description. */
  .nb-showcase-body h2 {
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.025em;
    color: var(--nb-foreground);
    scroll-margin-top: 5rem;
    margin: 0 0 0.375rem;
  }
  .nb-showcase-body h3 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--nb-foreground);
    scroll-margin-top: 5rem;
    margin: 0 0 0.25rem;
  }
  .nb-showcase-body h3 + p {
    font-size: 0.875rem;
    color: var(--nb-muted-foreground);
    line-height: 1.6;
    max-width: 42rem;
    /* Pull the description up tight against its heading. The parent
       has `gap-10` for spacing between example blocks; a caption is
       not a block — it belongs to the heading above it. Negative
       margin compensates for the flex gap that would otherwise
       separate them by 2.5rem. */
    margin: -2.25rem 0 0;
  }
  /* Mobile: the flex `gap-10` between section h2s and the first example
     h3 reads too loose on narrow viewports — pull the first h3 closer
     to its section heading so the group stays cohesive. */
  @media (max-width: 767px) {
    .nb-showcase-body h2 + h3 {
      margin-top: -1.5rem;
    }
  }
  /* Override the global hide so a literal "mdx" pill appears for code
     that's typed as tsx (for shiki tokenization) but is really mdx. */
  .nb-showcase-content .nb-showcase-mdx-tag .nb-code-figure::before {
    content: "mdx";
    display: inline-block !important;
    position: absolute;
    top: 0.5rem;
    right: 0.625rem;
    padding: 0.0625rem 0.375rem;
    border-radius: 0.25rem;
    background: var(--nb-muted);
    color: var(--nb-muted-foreground);
    font-family: var(--nb-font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    opacity: 0.75;
    z-index: 1;
  }
</style>

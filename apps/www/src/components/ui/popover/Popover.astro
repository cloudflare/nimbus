---
/**
 * Popover — anchored floating content. Compose with PopoverTrigger +
 * PopoverContent. Built on the native Popover API; positioned via JS
 * at open time and on scroll/resize.
 */
import { cn } from "@/lib/cn";
import type { HTMLAttributes } from "astro/types";

type Props = HTMLAttributes<"div">;

const { class: className, ...attrs } = Astro.props;
// Deterministic ID — per-page counter on Astro.locals. See PackageManagers
// for the rationale.
const localsAny = Astro.locals as Record<string, unknown>;
const counters =
  (localsAny.__nbCounters as Map<string, number>) ??
  (localsAny.__nbCounters = new Map<string, number>());
const n = (counters.get("popover") ?? 0) + 1;
counters.set("popover", n);
const popoverId = `popover-${n.toString(16).padStart(8, "0")}`;
---

<div class={cn("relative inline-block", className)} data-popover-root data-popover-id={popoverId} {...attrs}>
  <slot />
</div>

<script>
  import "./popover.client";
</script>

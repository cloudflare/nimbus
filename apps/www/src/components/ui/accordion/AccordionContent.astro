---
/** AccordionContent — animated panel; padding aligns with trigger title. */
import { cn } from "@/lib/cn";
import type { HTMLAttributes } from "astro/types";
import CollapsibleContent from "../collapsible/CollapsibleContent.astro";

interface Props extends HTMLAttributes<"div"> {}

const { class: className, ...attrs } = Astro.props;
---

<CollapsibleContent class={cn(className)} {...attrs}>
  <div
    class={cn(
      "px-5 pb-5 text-sm leading-relaxed text-muted-foreground",
      "[&_p:first-child]:mt-0 [&_p:last-child]:mb-0",
      "[&_p+p]:mt-2",
    )}
  >
    <slot />
  </div>
</CollapsibleContent>

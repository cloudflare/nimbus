# Re-enable npm's pre/post script lifecycle hooks. pnpm 7+ disabled them
# by default, which silently broke `pnpm run build` in apps/www — that
# script relies on `prebuild` to build `nimbus-docs` and emit the registry
# before `astro build` runs. Without this, Cloudflare Pages deploys
# without the registry files and `nimbus-docs add <slug>` 404s.
enable-pre-post-scripts=true

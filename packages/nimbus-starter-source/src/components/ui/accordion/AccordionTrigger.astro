---
/** AccordionTrigger — toggle row with chevron + slotted label. */
import { Icon } from "astro-icon/components";
import { cn } from "@/lib/cn";
import type { HTMLAttributes } from "astro/types";
import CollapsibleTrigger from "../collapsible/CollapsibleTrigger.astro";

interface Props extends HTMLAttributes<"button"> {}

const { class: className, ...attrs } = Astro.props;
---

<CollapsibleTrigger
  class={cn(
    "group/nb-acc flex items-center gap-2.5 px-5 py-3.5 text-sm font-medium text-foreground",
    "transition-colors duration-100 hover:bg-accent",
    className,
  )}
  {...attrs}
>
  <span class="min-w-0 flex-1 text-left">
    <slot />
  </span>
  {/* is:inline renders the full svg — sprite refs break when the first
     usage on a page lands in discarded conditional markup. */}
  <Icon
    name="ph:caret-right"
    is:inline
    class={cn(
      "shrink-0 w-4 h-4 text-muted-foreground",
      "transition-[transform,color] duration-[250ms] ease-[cubic-bezier(0.87,0,0.13,1)]",
      "group-hover/nb-acc:text-foreground",
      "group-data-[nb-state=open]/nb-acc:rotate-90 group-data-[nb-state=open]/nb-acc:text-foreground",
      "motion-reduce:transition-none",
    )}
  />
</CollapsibleTrigger>

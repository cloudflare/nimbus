{
	"name": "@cloudflare/nimbus-docs",
	"version": "0.7.1",
	"private": false,
	"publishConfig": {
		"access": "public"
	},
	"type": "module",
	"description": "Docs, for humans and agents",
	"keywords": [
		"astro",
		"documentation",
		"docs",
		"mdx",
		"static-site"
	],
	"homepage": "https://nimbus-docs.com",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/cloudflare/nimbus.git",
		"directory": "packages/nimbus-docs"
	},
	"bugs": {
		"url": "https://github.com/cloudflare/nimbus/issues"
	},
	"license": "MIT",
	"author": "Mohamed Hassan",
	"bin": {
		"nimbus-docs": "./dist/cli/index.js"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./content": {
			"types": "./dist/content.d.ts",
			"import": "./dist/content.js"
		},
		"./schemas": {
			"types": "./dist/schemas.d.ts",
			"import": "./dist/schemas.js"
		},
		"./types": {
			"types": "./dist/types.d.ts",
			"import": "./dist/types.js"
		},
		"./client": {
			"types": "./dist/client.d.ts",
			"import": "./dist/client.js"
		},
		"./markdown": {
			"types": "./dist/markdown.d.ts",
			"import": "./dist/markdown.js"
		},
		"./react": {
			"types": "./dist/react.d.ts",
			"import": "./dist/react.js"
		},
		"./lib/pkgm": {
			"types": "./dist/lib/pkgm.d.ts",
			"import": "./dist/lib/pkgm.js"
		},
		"./components/NimbusHead.astro": "./src/components/NimbusHead.astro"
	},
	"files": [
		"dist",
		"src/components"
	],
	"engines": {
		"node": ">=22.12.0"
	},
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"typecheck": "tsc --noEmit",
		"test": "node --import tsx --test \"test/**/*.test.ts\"",
		"prepack": "tsdown"
	},
	"peerDependencies": {
		"astro": "^7.0.0",
		"react": ">=19.0.0",
		"react-dom": ">=19.0.0"
	},
	"peerDependenciesMeta": {
		"react": {
			"optional": true
		},
		"react-dom": {
			"optional": true
		}
	},
	"dependencies": {
		"@astrojs/markdown-satteri": "^0.3.4",
		"@astrojs/mdx": "^7.0.3",
		"@astrojs/sitemap": "^3.7.2",
		"@clack/prompts": "^0.9.1",
		"@shikijs/transformers": "^4.2.0",
		"@shikijs/types": "^4.2.0",
		"@vercel/detect-agent": "^1.2.3",
		"clsx": "^2.1.1",
		"giget": "^3.3.0",
		"github-slugger": "^2.0.0",
		"mri": "^1.2.0",
		"picomatch": "^4.0.5",
		"remark-lint-emphasis-marker": "^4.0.1",
		"remark-lint-fenced-code-flag": "^4.2.0",
		"remark-lint-heading-increment": "^4.0.1",
		"remark-lint-no-duplicate-headings": "^4.0.1",
		"remark-lint-no-heading-punctuation": "^4.0.1",
		"remark-lint-no-literal-urls": "^4.0.1",
		"remark-lint-no-multiple-toplevel-headings": "^4.0.1",
		"remark-lint-unordered-list-marker-style": "^4.0.1",
		"satteri": "^0.9.1",
		"shiki": "^4.0.0",
		"tailwind-merge": "^3.5.0",
		"unified": "^11.0.5",
		"vfile": "^6.0.3",
		"yaml": "^2.7.1"
	},
	"devDependencies": {
		"@mdx-js/mdx": "^3.1.1",
		"@types/picomatch": "^4.0.3",
		"@types/react": "^19.2.6",
		"@types/react-dom": "^19.2.3",
		"astro": "^7.0.0",
		"jsdom": "^29.1.1",
		"tsdown": "^0.20.3",
		"tsx": "^4.22.3",
		"typescript": "^5.8.3",
		"vite": "^8.0.0"
	}
}
